# Backend (Spring Boot) — ejemplo
# NO subas un .env real con secretos.

# Dominio Auth0 (sin https:// y sin trailing slash)
# Ej: dev-xxxxxx.us.auth0.com
AUTH0_DOMAIN=

# Audience / API Identifier (Auth0 API -> Identifier)
# Ej: https://lab10-tdsn-api
AUTH0_AUDIENCE=https://lab10-tdsn-api

# Orígenes permitidos para CORS (separados por coma)
# Ej: http://localhost:5173,https://TU_BUCKET.s3-website-REGION.amazonaws.com
CORS_ALLOWED_ORIGINS=http://localhost:5173
